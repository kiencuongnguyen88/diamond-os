  "machine_execution": {
    "runs_before_true_human_gate": [
      "classify_request_and_operational_need",
      "create_sandbox_for_source_DB_file_patch_or_audit_tasks",
      "route_objects_to_correct_role",
      "run_BFL_until_converged_or_BLOCKED",
      "inspect_schema_FK_duplicate_and_proof",
      "create_candidate_repair_dry_run_and_readback",
      "emit_PASS_ADOPTABLE_BLOCKED_REPAIR_REQUIRED_or_FAIL_RETRY"
    ],
    "must_not_delegate_to_human": [
      "machine_checkable_role_fit",
      "row_by_row_schema_review",
      "routine_BFL_or_proof_audit"
    ],
    "sandbox_pass_is_not_live_adoption": true
  },
  "human_gate": {
    "purpose": "authority_not_routine_machine_labor",
    "options": [
      "approve",
      "reject",
      "revise",
      "fail_retry"
    ],
    "required_for": [
      "active_source_or_DB_replacement",
      "live_DB_or_RLDB_write",
      "canon_promotion",
      "destructive_action",
      "external_publish_send_share",
      "privacy_sensitive_export",
      "unresolved_authority_conflict",
      "repository_commit_or_push"
    ],
    "not_required_for": [
      "readonly_inspection",
      "sandbox_creation",
      "candidate_build",
      "BFL_self_review",
      "dry_run",
      "readback_packaging"
    ]
  },
  "proof_and_readback": {
    "visible_required": [
      "self_review_verdict",
      "checks_completed",
      "changed_and_not_changed",
      "exact_human_gate",
      "next_valid_move"
    ],
    "cannot_be_replaced_by_artifact_only": true
  },
  "relation_to_drc17": {
    "audit_contract_ref": "data/runtime-contracts/drc17-audit-contract.json",
    "audit_verdict_must_surface_in_DRC16": true
  },
  "claim_boundary": {
    "source_apply": false,
    "DB_write": false,
    "RLDB_writeback": false,
    "canon": false,
    "commit": false,
    "push": false,
    "publish": false,
    "runtime_activation": false
  }
}
