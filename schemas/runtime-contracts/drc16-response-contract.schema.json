    "unit_id",
    "version",
    "state",
    "role",
    "source_refs",
    "source_selection",
    "layer_contract",
    "visible_surface",
    "machine_execution",
    "human_gate",
    "proof_and_readback",
    "relation_to_drc17",
    "claim_boundary"
