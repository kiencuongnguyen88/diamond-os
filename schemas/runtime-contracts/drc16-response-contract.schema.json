      "properties": {
        "source_apply": {
          "const": false
        },
        "DB_write": {
          "const": false
        },
        "RLDB_writeback": {
          "const": false
        },
        "canon": {
          "const": false
        },
        "commit": {
          "const": false
        },
        "push": {
          "const": false
        },
        "publish": {
          "const": false
        },
        "runtime_activation": {
          "const": false
        }
      },
      "additionalProperties": false
    },
    "source_selection": {
      "type": "object"
    },
    "layer_contract": {
      "type": "object"
    },
    "visible_surface": {
      "type": "object"
    },
    "machine_execution": {
      "type": "object"
    },
    "human_gate": {
      "type": "object"
    },
    "proof_and_readback": {
      "type": "object"
    },
    "relation_to_drc17": {
      "type": "object"
    }
  },
