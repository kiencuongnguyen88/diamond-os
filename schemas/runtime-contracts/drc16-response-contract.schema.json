  "properties": {
    "contract_id": {
      "const": "DRC16_PUBLIC_RESPONSE_RUNTIME_CONTRACT_v0_1"
    },
    "unit_id": {
      "const": "PG-U02"
    },
    "version": {
      "const": "v0.1"
    },
    "state": {
      "const": "GIT_CANDIDATE"
