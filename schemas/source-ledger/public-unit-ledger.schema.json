{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kiencuongnguyen88/diamond-os/schemas/source-ledger/public-unit-ledger.schema.json",
  "title": "DIAMOND OS Public Unit Ledger",
  "type": "object",
  "required": [
    "ledger_id",
    "schema_version",
    "repository",
    "units",
    "claim_boundary"
  ],
  "properties": {
    "ledger_id": {
      "const": "DZN32_PUBLIC_UNIT_LEDGER_v0_1"
    },
    "schema_version": {
      "const": "v0.1"
    },
    "repository": {
      "type": "object",
      "required": [
        "full_name",
        "branch",
        "base_head"
      ],
      "properties": {
        "full_name": {
          "const": "kiencuongnguyen88/diamond-os"
        },
        "branch": {
          "const": "main"
        },
        "base_head": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      },
      "additionalProperties": false
    },
    "units": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "unit_id",
          "name",
          "migration_order",
          "state",
          "authority",
          "canon",
          "dependency_unit_ids",
          "source_hashes",
          "human_gate",
          "proof_refs",
          "repository_binding",
          "claim_boundary"
        ],
        "properties": {
          "unit_id": {
            "type": "string",
            "pattern": "^PG-U[0-9]{2}$"
          },
          "name": {
            "type": "string",
            "minLength": 3
          },
          "migration_order": {
            "type": "integer",
            "minimum": 1
          },
          "state": {
            "enum": [
              "GIT_CANDIDATE",
              "GIT_VERIFIED",
              "GIT_CANONICAL",
              "DEFERRED",
              "BLOCKED"
            ]
          },
          "authority": {
            "type": "boolean"
          },
          "canon": {
            "type": "boolean"
          },
          "dependency_unit_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "source_hashes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "source_ref_id",
                "sha256"
              ],
              "properties": {
                "source_ref_id": {
                  "type": "string"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                }
              },
              "additionalProperties": false
            }
          },
          "human_gate": {
            "type": "object",
            "required": [
              "state",
              "action",
              "exact_scope"
            ],
            "properties": {
              "state": {
                "type": "string"
              },
              "action": {
                "type": "string"
              },
              "exact_scope": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "proof_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "repository_binding": {
            "type": "object",
            "required": [
              "mode",
              "base_commit"
            ],
            "properties": {
              "mode": {
                "enum": [
                  "exact_commit",
                  "containing_commit"
                ]
              },
              "base_commit": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              },
              "commit_sha": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^[0-9a-f]{40}$"
              }
            },
            "additionalProperties": false
          },
          "claim_boundary": {
            "type": "object",
            "required": [
              "source_apply",
              "DB_write",
              "RLDB_writeback",
              "canon",
              "commit",
              "push",
              "publish",
              "runtime_activation"
            ],
            "properties": {
              "source_apply": {
                "const": false
              },
              "DB_write": {
                "const": false
              },
              "RLDB_writeback": {
                "const": false
              },
              "canon": {
                "const": false
              },
              "commit": {
                "const": false
              },
              "push": {
                "const": false
              },
              "publish": {
                "const": false
              },
              "runtime_activation": {
                "const": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "claim_boundary": {
      "type": "object",
      "required": [
        "source_apply",
        "DB_write",
        "RLDB_writeback",
        "canon",
        "commit",
        "push",
        "publish",
        "runtime_activation"
      ],
      "properties": {
        "source_apply": {
          "const": false
        },
        "DB_write": {
          "const": false
        },
        "RLDB_writeback": {
          "const": false
        },
        "canon": {
          "const": false
        },
        "commit": {
          "const": false
        },
        "push": {
          "const": false
        },
        "publish": {
          "const": false
        },
        "runtime_activation": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
