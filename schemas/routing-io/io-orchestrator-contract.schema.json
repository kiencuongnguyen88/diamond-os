{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kiencuongnguyen88/diamond-os/schemas/routing-io/io-orchestrator-contract.schema.json",
  "title": "PG-U03 IO Orchestrator Contract",
  "type": "object",
  "required": [
    "contract_id",
    "unit_id",
    "state",
    "canon",
    "source_selection",
    "scope_lock",
    "visible_flow",
    "human_ownership",
    "system_ownership",
    "agency_axis",
    "orchestration_axis",
    "selection_order",
    "selection_rule",
    "authority_tuple",
    "optional_context_rule",
    "route_map",
    "stop_codes",
    "proof_contract",
    "claim_boundary"
  ],
  "properties": {
    "contract_id": {
      "const": "PG_U03_IO_ORCHESTRATOR_CONTRACT_v0_1"
    },
    "unit_id": {
      "const": "PG-U03"
    },
    "state": {
      "const": "GIT_CANDIDATE"
    },
    "canon": {
      "const": false
    },
    "source_selection": {
      "type": "object"
    },
    "scope_lock": {
      "type": "object"
    },
    "visible_flow": {
      "const": [
        "input_readback",
        "output_contract",
        "result",
        "proof",
        "human_gate"
      ]
    },
    "human_ownership": {
      "type": "array",
      "minItems": 3
    },
    "system_ownership": {
      "type": "array",
      "minItems": 5
    },
    "agency_axis": {
      "type": "object"
    },
    "orchestration_axis": {
      "type": "object"
    },
    "selection_order": {
      "type": "array",
      "minItems": 8
    },
    "selection_rule": {
      "type": "string"
    },
    "authority_tuple": {
      "type": "object"
    },
    "optional_context_rule": {
      "type": "object"
    },
    "route_map": {
      "type": "object"
    },
    "stop_codes": {
      "type": "object"
    },
    "proof_contract": {
      "type": "array",
      "minItems": 8
    },
    "claim_boundary": {
      "type": "object",
      "required": [
        "source_apply",
        "DB_write",
        "RLDB_writeback",
        "canon",
        "commit",
        "push",
        "publish",
        "runtime_activation"
      ],
      "properties": {
        "source_apply": {
          "const": false
        },
        "DB_write": {
          "const": false
        },
        "RLDB_writeback": {
          "const": false
        },
        "canon": {
          "const": false
        },
        "commit": {
          "const": false
        },
        "push": {
          "const": false
        },
        "publish": {
          "const": false
        },
        "runtime_activation": {
          "const": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
